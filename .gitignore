## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# Visual Studio cache/options directory
.vs/

# Build results
bin/
obj/

# Build logs
*.log
build_*.log

# Executables
*.exe
*.dll
*.pdb

# NuGet
*.nupkg
*.nuget.props
*.nuget.targets

# User-specific files
*.user
*.suo
*.userprefs

# Rider
.idea/
*.sln.iml

# Test Results
TestResults/

# Coverage
coverage/
